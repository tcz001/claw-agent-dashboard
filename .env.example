# === Required Configuration ===

# Path to your OpenClaw workspace directory on the host
OPENCLAW_HOME=~/.openclaw

# Path to writable data directory (translations, config)
DATA_HOST_DIR=./data

# OpenClaw Gateway URL
GATEWAY_URL=http://host.docker.internal:18789

# OpenClaw Gateway authentication token
GATEWAY_TOKEN=

# === Optional Configuration ===
# Uncomment and set these to enable additional features.

# Path to global OpenClaw skills directory (for global skills browser)
# OPENCLAW_SKILLS_DIR=/usr/lib/node_modules/openclaw/skills

# Path to OpenClaw log directory (for event parsing in dashboard)
# OPENCLAW_LOGS_DIR=/tmp/openclaw

# Path to OpenClaw agents data directory (for detailed session info)
# OPENCLAW_AGENTS_DIR=~/.openclaw/agents

# === Build Configuration (optional) ===

# Custom npm registry for building behind a proxy/mirror
# NPM_REGISTRY=https://registry.npmmirror.com/

# Custom PyPI index for building behind a proxy/mirror
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple/

# === Advanced (optional) ===

# Uncomment the /proc volume mount in docker-compose.yml to enable
# host system metrics (CPU, memory, disk) in the dashboard.
# This is read-only and only used for display purposes.
# Note: extra_hosts is needed on Linux for host.docker.internal resolution.
